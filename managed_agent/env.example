# Required for the native Deepline v2 broker
DEEPLINE_API_KEY=

# Optional Anthropic Managed Agent shell configuration
# ANTHROPIC_API_KEY=
# MANAGED_AGENT_ID=
# MANAGED_ENVIRONMENT_ID=

# Asset paths (defaults shown — override if deploying to a non-standard location)
# DEEPLINE_BIN=/usr/local/bin/deepline
# DEEPLINE_AUTH=/root/.local/deepline/code-deepline-com/.env
# GTM_SKILL_DIR=/app/deepline-gtm

# Server
PORT=8000
# API_KEY=          # Optional: protect /chat endpoints with bearer token
# CORS_ORIGINS=*    # Comma-separated origins for production

# Slack (optional)
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=

# Redis (optional)
# REDIS_URL=
