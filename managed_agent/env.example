# Required for the native Deepline v2 broker
DEEPLINE_API_KEY=

# Optional Anthropic Managed Agent shell configuration
# ANTHROPIC_API_KEY=
# MANAGED_AGENT_ID=
# MANAGED_ENVIRONMENT_ID=

# Server
PORT=8000
# API_KEY=          # Required for /chat endpoints in production
# ALLOW_UNAUTHENTICATED=false  # Local/dev escape hatch only
# CORS_ORIGINS=     # Comma-separated browser origins; empty means no browser CORS
# DEFAULT_CHAT_TOOL_IDS=deeplineagent,serper_google_search,exa_search,firecrawl_scrape,discolike_run_company_research,exa_company_search,limadata_find_person_profiles,allegrow_validate,leadmagic_email_validation
# ALLOWED_CLIENT_TOOL_IDS=deeplineagent,serper_google_search,exa_search,firecrawl_scrape,discolike_run_company_research,exa_company_search,limadata_find_person_profiles,allegrow_validate,leadmagic_email_validation,snowflake_query,snowflake_execute_query
# DEFAULT_MAX_TOOL_CALLS=6
# MAX_TOOL_CALLS_LIMIT=12

# Slack (optional)
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_OAUTH_STATE=          # Required for /slack/oauth_redirect
# SLACK_ALLOWED_CHANNEL_IDS=  # Required with/or SLACK_ALLOWED_USER_IDS
