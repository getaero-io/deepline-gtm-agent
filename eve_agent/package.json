  },
  "dependencies": {
    "ai": "latest",
    "eve": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vercel": "^54.14.5"
