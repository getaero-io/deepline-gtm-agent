{
  "name": "deepline-gtm-eve-agent",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "eve dev",
    "info": "eve info",
    "link": "eve link",
    "build": "eve build",
    "start": "eve start",
    "deploy": "eve deploy",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "eval": "eve eval",
