# Core — required
DEEPLINE_API_KEY=

# LLM — one of these required
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Model selection (default: anthropic:claude-opus-4-6)
# Also accepts: openai:gpt-4o, google:gemini-2.0-flash
LLM_MODEL=anthropic:claude-opus-4-6

# Server
PORT=8000

# Slack bot (optional — required for Slack integration only)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Advanced (optional)
DEEPLINE_API_BASE_URL=https://code.deepline.com
