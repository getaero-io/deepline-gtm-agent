# Core — required
DEEPLINE_API_KEY=

# LLM — one of these required
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Model selection (default: anthropic:claude-opus-4-6)
# Also accepts: openai:gpt-4o, google:gemini-2.0-flash
LLM_MODEL=anthropic:claude-opus-4-6

# Server
PORT=8000
# Optional: restrict CORS to specific origins in production (comma-separated).
# Defaults to "*" (open). Example: CORS_ORIGINS=https://your-app.com
# CORS_ORIGINS=*
# Optional: protect /chat endpoints with a bearer token.
# Leave unset to run open (local dev only).
# API_KEY=

# Slack bot (optional — required for Slack integration only)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Redis (optional — enables per-thread conversation history in Slack)
# REDIS_URL=redis://localhost:6379

# Advanced (optional)
DEEPLINE_API_BASE_URL=https://code.deepline.com

# Direct provider keys (optional — for local development without Deepline routing)
# These are NOT required when using DEEPLINE_API_KEY. Set them only if you want
# to call providers directly, bypassing Deepline's proxy.
# APOLLO_API_KEY=
# CRUSTDATA_API_KEY=
# EXA_API_KEY=
# FIRECRAWL_API_KEY=
