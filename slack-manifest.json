{
  "_metadata": {
    "major_version": 1,
    "minor_version": 1
  },
  "display_information": {
    "name": "Deepline GTM Agent",
    "description": "AI-powered GTM agent — prospect search, contact enrichment, email verification, and account research.",
    "background_color": "#0d1117"
  },
  "features": {
    "bot_user": {
      "display_name": "Deepline GTM Agent",
      "always_online": true
    }
  },
  "oauth_config": {
    "redirect_urls": [
      "https://YOUR_RAILWAY_DOMAIN/slack/oauth_redirect"
    ],
    "scopes": {
      "bot": [
        "app_mentions:read",
        "channels:history",
        "channels:read",
        "chat:write",
        "chat:write.public",
        "groups:history",
        "im:history",
        "im:read",
        "mpim:history",
        "reactions:write"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://YOUR_RAILWAY_DOMAIN/slack/events",
      "bot_events": [
        "app_mention",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": false
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
